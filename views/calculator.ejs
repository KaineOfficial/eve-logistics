<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <title><%= t.calc.title %> — TSLC</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container" style="max-width:620px">
    <div class="page-header" style="margin-bottom:8px">
      <h1><%= t.calc.title %></h1>
    </div>
    <p style="margin-top:0;margin-bottom:24px;color:#64748b;font-size:0.9rem"><%= t.calc.subtitle %></p>

    <div class="calc-form">
      <!-- Route selector -->
      <div class="form-group">
        <label for="route-select"><%= t.calc.labelRoute || 'Route' %></label>
        <select id="route-select" class="search-input" style="cursor:pointer">
          <option value="standard"><%= t.calc.standardRoute || 'Standard (default)' %></option>
          <% routes.forEach(route => { %>
            <option value="<%= route.id %>"><%= route.point_a %> ↔ <%= route.point_b %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="volume"><%= t.calc.labelVolume %></label>
        <input type="number" id="volume" placeholder="ex: 50000" min="0">
        <span class="field-hint" id="volume-hint"></span>
      </div>

      <div class="form-group">
        <label for="collateral"><%= t.calc.labelCollateral %></label>
        <input type="number" id="collateral" placeholder="ex: 2000000000" min="0">
        <span class="field-hint" id="collateral-hint"></span>
      </div>

      <div class="calc-result" id="result-box">
        <div class="result-row">
          <span class="result-label"><%= t.calc.rate %></span>
          <span class="result-value" id="result-rate">—</span>
        </div>
        <div class="result-row" id="surcharge-row" style="display:none">
          <span class="result-label" id="surcharge-label">Surcharge</span>
          <span class="result-value" id="result-surcharge">—</span>
        </div>
        <% if (jumpEnabled) { %>
        <div class="result-row" id="jumps-row" style="display:none">
          <span class="result-label">Jumps</span>
          <span class="result-value" id="result-jumps">—</span>
        </div>
        <% } %>
        <div class="result-row result-total">
          <span class="result-label"><%= t.calc.reward %></span>
          <span class="result-value result-isk" id="result-reward">—</span>
        </div>
        <div class="result-error" id="result-error" style="display:none"></div>
      </div>
    </div>

    <!-- Current route info -->
    <div style="margin-top:32px" id="pricing-info">
      <div class="standards-header" style="border-radius:8px 8px 0 0;border:1px solid #334155;border-bottom:none">
        <span class="standards-title" id="pricing-title"><%= t.calc.tiersTitle %></span>
      </div>
      <div class="pricing-table" style="border-radius:0 0 8px 8px;border-top:none" id="pricing-table">
        <!-- Filled by JS -->
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    const STANDARD = {
      tiers: <%- JSON.stringify(standards.tiers) %>,
      maxVolume: <%= standards.maxVolume %>,
      maxCollateral: <%= standards.maxCollateral %>,
      surcharge: 0,
      surchargeLabel: '',
    };

    const ROUTES = {
      <% routes.forEach(route => { %>
      '<%= route.id %>': {
        name: '<%- route.point_a %> \u2194 <%- route.point_b %>',
        pointA: '<%- route.point_a %>',
        pointB: '<%- route.point_b %>',
        tiers: <%- JSON.stringify(route.tiers) %>,
        maxVolume: <%= route.max_volume %>,
        surcharge: <%= route.surcharge %>,
        surchargeLabel: '<%- route.surcharge_label %>',
      },
      <% }) %>
    };

    const JUMP_ENABLED = <%= jumpEnabled ? 'true' : 'false' %>;
    const JUMP_PRICE_PER_M3 = <%= jumpPricePerM3 %>;
    let currentJumps = null;
    let jumpCache = {};

    const volInput    = document.getElementById('volume');
    const colInput    = document.getElementById('collateral');
    const routeSelect = document.getElementById('route-select');
    const resRate     = document.getElementById('result-rate');
    const resReward   = document.getElementById('result-reward');
    const resError    = document.getElementById('result-error');
    const volHint     = document.getElementById('volume-hint');
    const colHint     = document.getElementById('collateral-hint');

    const t = {
      errVolume:     "<%= t.calc.errVolume %>",
      errCollateral: "<%= t.calc.errCollateral %>",
      errNoTier:     "<%= t.calc.errNoTier %>",
    };

    function fmt(n) { return Math.round(n).toLocaleString(); }

    function getConfig() {
      const val = routeSelect.value;
      return val === 'standard' ? STANDARD : (ROUTES[val] || STANDARD);
    }

    function renderPricing() {
      const cfg = getConfig();
      const table = document.getElementById('pricing-table');
      const title = document.getElementById('pricing-title');
      title.textContent = routeSelect.value === 'standard'
        ? '<%= t.calc.tiersTitle %>'
        : cfg.name;

      let html = '<div class="pricing-row"><span>Collateral</span><span>Rate/m\u00B3</span></div>';
      cfg.tiers.forEach(tier => {
        html += '<div class="pricing-row" style="border-top:1px solid #1e293b;padding-top:6px;margin-top:4px">';
        html += '<span>&le; ' + fmt(tier.maxCollateral / 1e9) + ' B ISK</span>';
        html += '<span class="pricing-rate">' + fmt(tier.ratePerM3) + ' ISK/m\u00B3</span>';
        html += '</div>';
      });
      if (cfg.surcharge > 0) {
        html += '<div class="pricing-row pricing-limit-row">';
        html += '<span>' + (cfg.surchargeLabel || 'Surcharge') + '</span>';
        html += '<span class="pricing-rate">+' + fmt(cfg.surcharge) + ' ISK</span>';
        html += '</div>';
      }
      html += '<div class="pricing-row pricing-limit-row"><span>Max volume</span><span>' + fmt(cfg.maxVolume) + ' m\u00B3</span></div>';
      table.innerHTML = html;
    }

    function calculate() {
      const cfg = getConfig();
      const vol = parseFloat(volInput.value);
      const col = parseFloat(colInput.value);

      resError.style.display = 'none';
      resRate.textContent   = '\u2014';
      resReward.textContent = '\u2014';
      volHint.textContent   = '';
      colHint.textContent   = '';
      volHint.className = 'field-hint';
      colHint.className = 'field-hint';

      const surchargeRow = document.getElementById('surcharge-row');
      if (surchargeRow) surchargeRow.style.display = 'none';
      const jumpsRow = document.getElementById('jumps-row');
      if (jumpsRow) jumpsRow.style.display = 'none';

      if (!volInput.value && !colInput.value) return;

      if (isNaN(vol) || vol <= 0) return;
      if (vol > cfg.maxVolume) {
        const msg = t.errVolume.replace('200,000', fmt(cfg.maxVolume)).replace('200 000', fmt(cfg.maxVolume));
        volHint.textContent = msg;
        volHint.className = 'field-hint hint-error';
        resError.textContent = msg;
        resError.style.display = 'block';
        return;
      }
      volHint.textContent = fmt(vol) + ' m\u00B3';
      volHint.className = 'field-hint hint-ok';

      if (!colInput.value || isNaN(col) || col < 0) return;

      // Find max collateral from tiers
      const maxCol = cfg.tiers.length > 0 ? cfg.tiers[cfg.tiers.length - 1].maxCollateral : 0;
      if (maxCol > 0 && col > maxCol) {
        const limit = maxCol >= 1e9 ? fmt(maxCol / 1e9) + ' B ISK' : fmt(maxCol / 1e6) + ' M ISK';
        const msg = 'Collateral exceeds the ' + limit + ' limit.';
        colHint.textContent = msg;
        colHint.className = 'field-hint hint-error';
        resError.textContent = msg;
        resError.style.display = 'block';
        return;
      }
      colHint.textContent = fmt(col) + ' ISK';
      colHint.className = 'field-hint hint-ok';

      const tier = cfg.tiers.find(t => col <= t.maxCollateral);
      if (!tier) {
        resError.textContent = t.errNoTier;
        resError.style.display = 'block';
        return;
      }

      let reward = vol * tier.ratePerM3;
      resRate.textContent = fmt(tier.ratePerM3) + ' ISK/m\u00B3';

      // Surcharge
      if (cfg.surcharge > 0 && surchargeRow) {
        surchargeRow.style.display = 'flex';
        document.getElementById('surcharge-label').textContent = cfg.surchargeLabel || 'Surcharge';
        document.getElementById('result-surcharge').textContent = '+' + fmt(cfg.surcharge) + ' ISK';
        reward += cfg.surcharge;
      }

      // Jump cost
      if (JUMP_ENABLED && currentJumps !== null && currentJumps > 0 && JUMP_PRICE_PER_M3 > 0) {
        const jumpCost = vol * JUMP_PRICE_PER_M3 * currentJumps;
        if (jumpsRow) {
          jumpsRow.style.display = 'flex';
          document.getElementById('result-jumps').textContent = currentJumps + ' jumps → +' + fmt(jumpCost) + ' ISK';
        }
        reward += jumpCost;
      }

      resReward.textContent = fmt(reward) + ' ISK';
    }

    async function fetchJumps(routeId) {
      const cfg = ROUTES[routeId];
      if (!cfg || !JUMP_ENABLED) { currentJumps = null; return; }

      const cacheKey = cfg.pointA + '|' + cfg.pointB;
      if (jumpCache[cacheKey] !== undefined) {
        currentJumps = jumpCache[cacheKey];
        calculate();
        return;
      }

      try {
        const res = await fetch('/api/jumps?from=' + encodeURIComponent(cfg.pointA) + '&to=' + encodeURIComponent(cfg.pointB));
        const data = await res.json();
        if (data.jumps !== undefined) {
          currentJumps = data.jumps;
          jumpCache[cacheKey] = data.jumps;
        } else {
          currentJumps = null;
        }
      } catch {
        currentJumps = null;
      }
      calculate();
    }

    routeSelect.addEventListener('change', () => {
      renderPricing();
      currentJumps = null;
      if (routeSelect.value !== 'standard') {
        fetchJumps(routeSelect.value);
      }
      calculate();
    });
    volInput.addEventListener('input', calculate);
    colInput.addEventListener('input', calculate);

    // Init
    renderPricing();
  </script>
</body>
</html>

<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('partials/head') %>
  <title><%= t.leaderboard.title %> — Tilean Dominion</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container wide">
    <div class="page-header">
      <h1><%= t.leaderboard.title %></h1>
    </div>

    <!-- Stats globales -->
    <div class="stat-cards">
      <div class="stat-card pending">
        <div class="stat-number"><%= globalStats.totalContracts %></div>
        <div class="stat-label"><%= t.leaderboard.totalContracts %></div>
      </div>
      <div class="stat-card delivered">
        <div class="stat-number"><%= globalStats.delivered %></div>
        <div class="stat-label"><%= t.leaderboard.delivered %></div>
      </div>
      <div class="stat-card in-transit">
        <div class="stat-number"><%= globalStats.totalVolume %></div>
        <div class="stat-label"><%= t.leaderboard.totalVolume %></div>
      </div>
      <div class="stat-card accepted">
        <div class="stat-number"><%= globalStats.totalReward %></div>
        <div class="stat-label"><%= t.leaderboard.totalReward %></div>
      </div>
    </div>

    <!-- Classement haulers -->
    <% if (haulers.length === 0) { %>
      <p class="no-contracts"><%= t.leaderboard.noHaulers %></p>
    <% } else { %>
      <table class="contracts-table">
        <thead>
          <tr>
            <th>#</th>
            <th><%= t.leaderboard.colHauler %></th>
            <th><%= t.leaderboard.colDelivered %></th>
            <th><%= t.leaderboard.colVolume %></th>
            <th><%= t.leaderboard.colReward %></th>
          </tr>
        </thead>
        <tbody>
          <% haulers.forEach((h, i) => { %>
            <tr class="<%= i < 3 ? 'leaderboard-top' : '' %>">
              <td class="rank-cell">
                <% if (i === 0) { %>
                  <span class="rank-medal gold">1</span>
                <% } else if (i === 1) { %>
                  <span class="rank-medal silver">2</span>
                <% } else if (i === 2) { %>
                  <span class="rank-medal bronze">3</span>
                <% } else { %>
                  <%= i + 1 %>
                <% } %>
              </td>
              <td>
                <div class="hauler-profile">
                  <img src="https://images.evetech.net/characters/<%= h.id %>/portrait?size=32" class="hauler-avatar">
                  <span><%= h.name %></span>
                </div>
              </td>
              <td><%= h.delivered %></td>
              <td><%= h.volume %> m³</td>
              <td><%= h.reward %> ISK</td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <!-- Top issuers -->
    <div class="section-header" style="margin-top:32px">
      <h2><%= t.leaderboard.topIssuers %></h2>
    </div>

    <% if (issuers.length === 0) { %>
      <p class="no-contracts"><%= t.leaderboard.noIssuers %></p>
    <% } else { %>
      <table class="contracts-table">
        <thead>
          <tr>
            <th>#</th>
            <th><%= t.leaderboard.colIssuer %></th>
            <th><%= t.leaderboard.colContracts %></th>
            <th><%= t.leaderboard.colVolume %></th>
          </tr>
        </thead>
        <tbody>
          <% issuers.forEach((s, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td>
                <div class="hauler-profile">
                  <img src="https://images.evetech.net/characters/<%= s.id %>/portrait?size=32" class="hauler-avatar">
                  <span><%= s.name %></span>
                </div>
              </td>
              <td><%= s.count %></td>
              <td><%= s.volume %> m³</td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</body>
</html>

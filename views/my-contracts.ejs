<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('partials/head') %>
  <title><%= t.myContracts.title %> — Tilean Dominion</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container wide">
    <div class="page-header">
      <h1><%= t.myContracts.title %></h1>
    </div>

    <!-- Stats perso -->
    <div class="stat-cards">
      <div class="stat-card pending">
        <div class="stat-number"><%= stats.outstanding %></div>
        <div class="stat-label"><%= t.dashboard.outstanding %></div>
      </div>
      <div class="stat-card in-transit">
        <div class="stat-number"><%= stats.in_progress %></div>
        <div class="stat-label"><%= t.dashboard.inProgress %></div>
      </div>
      <div class="stat-card delivered">
        <div class="stat-number"><%= stats.finished %></div>
        <div class="stat-label"><%= t.dashboard.finished %></div>
      </div>
      <div class="stat-card cancelled">
        <div class="stat-number"><%= stats.cancelled %></div>
        <div class="stat-label"><%= t.dashboard.cancelled %></div>
      </div>
    </div>

    <!-- Filtres -->
    <div class="filters" id="filters">
      <button class="filter-btn active" data-filter="all"><%= t.logistics.filterAll %> <span class="filter-count"><%= contracts.length %></span></button>
      <button class="filter-btn" data-filter="outstanding"><%= t.status.outstanding %> <span class="filter-count"><%= stats.outstanding %></span></button>
      <button class="filter-btn" data-filter="in_progress"><%= t.status.in_progress %> <span class="filter-count"><%= stats.in_progress %></span></button>
      <button class="filter-btn" data-filter="finished"><%= t.status.finished %> <span class="filter-count"><%= stats.finished %></span></button>
      <button class="filter-btn" data-filter="cancelled"><%= t.status.cancelled %> <span class="filter-count"><%= stats.cancelled %></span></button>
    </div>

    <% if (contracts.length === 0) { %>
      <p class="no-contracts"><%= t.myContracts.noContracts %></p>
    <% } else { %>
      <table class="contracts-table" id="contracts-table">
        <thead>
          <tr>
            <th><%= t.freight.colId %></th>
            <th><%= t.freight.colFrom %></th>
            <th><%= t.freight.colTo %></th>
            <th><%= t.freight.colVolume %></th>
            <th><%= t.freight.colCollateral %></th>
            <th><%= t.freight.colReward %></th>
            <th><%= t.freight.colStatus %></th>
            <th><%= t.freight.colHauler %></th>
            <th><%= t.logistics.colTimeLeft %></th>
          </tr>
        </thead>
        <tbody>
          <% contracts.forEach(c => { %>
            <%
              let filterGroup = c.status;
              if (['finished_issuer','finished_contractor'].includes(c.status)) filterGroup = 'finished';
              if (['rejected','failed','deleted','reversed'].includes(c.status)) filterGroup = 'cancelled';

              let timeLeft = '';
              const now = new Date();
              if (c.status === 'outstanding' && c.date_expired) {
                const diff = new Date(c.date_expired) - now;
                if (diff > 0) {
                  const days = Math.floor(diff / 86400000);
                  const hrs  = Math.floor((diff % 86400000) / 3600000);
                  timeLeft = days > 0 ? days + 'j ' + hrs + 'h' : hrs + 'h';
                }
              } else if (c.status === 'in_progress' && c.date_accepted && c.days_to_complete) {
                const deadline = new Date(new Date(c.date_accepted).getTime() + c.days_to_complete * 86400000);
                const diff = deadline - now;
                if (diff > 0) {
                  const days = Math.floor(diff / 86400000);
                  const hrs  = Math.floor((diff % 86400000) / 3600000);
                  timeLeft = days > 0 ? days + 'j ' + hrs + 'h' : hrs + 'h';
                }
              }
            %>
            <tr data-status="<%= filterGroup %>">
              <td>#<%= c.contract_id %></td>
              <td><%= c.start_name %></td>
              <td><%= c.end_name %></td>
              <td><%= c.volume ? c.volume.toLocaleString() : '—' %></td>
              <td><%= c.collateral ? c.collateral.toLocaleString() + ' ISK' : '—' %></td>
              <td><%= c.reward ? c.reward.toLocaleString() + ' ISK' : '—' %></td>
              <td><span class="status-badge status-<%= c.status %>"><%= t.status[c.status] || c.status %></span></td>
              <td><%= c.acceptor_name || '—' %></td>
              <td class="time-left"><%= timeLeft || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <%- include('partials/footer') %>

  <script>
    document.getElementById('filters')?.addEventListener('click', e => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      document.querySelectorAll('#contracts-table tbody tr').forEach(row => {
        row.style.display = (filter === 'all' || row.dataset.status === filter) ? '' : 'none';
      });
    });
  </script>
</body>
</html>

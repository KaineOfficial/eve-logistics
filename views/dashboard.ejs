<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <title><%= t.dashboard.title %> — TSLC</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">

    <div class="profile">
      <img src="<%= character.portrait %>" width="80" height="80">
      <div>
        <h2><%= character.name %></h2>
        <p><%= character.corporation %></p>
      </div>
    </div>

    <div class="stat-cards">
      <div class="stat-card pending">
        <div class="stat-number"><%= stats.pending %></div>
        <div class="stat-label"><%= t.dashboard.pending %></div>
      </div>
      <div class="stat-card accepted">
        <div class="stat-number"><%= stats.accepted %></div>
        <div class="stat-label"><%= t.dashboard.accepted %></div>
      </div>
      <div class="stat-card in-transit">
        <div class="stat-number"><%= stats.in_transit %></div>
        <div class="stat-label"><%= t.dashboard.inTransit %></div>
      </div>
      <div class="stat-card delivered">
        <div class="stat-number"><%= stats.delivered %></div>
        <div class="stat-label"><%= t.dashboard.delivered %></div>
      </div>
    </div>

    <% if (character.allianceId === allianceId) { %>
      <div class="hauler-summary">
        <div>
          <div class="hauler-summary-text"><%= t.dashboard.haulerActive %></div>
          <div class="hauler-summary-count"><%= activeCount %></div>
        </div>
        <a href="/hauler" class="nav-btn hauler"><%= t.dashboard.haulerBtn %></a>
      </div>
    <% } %>

    <div class="section-header">
      <h2><%= t.dashboard.myRequests %></h2>
      <a href="/freight"><%= t.dashboard.seeAll %></a>
    </div>

    <% if (myRequests.length === 0) { %>
      <p class="no-contracts">
        <%= t.dashboard.noRequests %>
        <a href="/freight/new" style="display:inline;padding:0;background:none;color:#3b82f6;font-weight:normal;"><%= t.dashboard.createRequest %></a>
      </p>
    <% } else { %>
      <table class="contracts-table">
        <thead>
          <tr>
            <th>#</th>
            <th><%= t.dashboard.colRoute %></th>
            <th><%= t.dashboard.colVolume %></th>
            <th><%= t.dashboard.colReward %></th>
            <th><%= t.dashboard.colStatus %></th>
            <th><%= t.dashboard.colHauler %></th>
          </tr>
        </thead>
        <tbody>
          <% myRequests.forEach(r => { %>
            <tr>
              <td>#<%= r.id %></td>
              <td><%= r.pickup %> → <%= r.destination %></td>
              <td><%= r.volume.toLocaleString() %></td>
              <td><%= r.reward ? r.reward.toLocaleString() + ' ISK' : '—' %></td>
              <td><span class="status-badge status-<%= r.status %>"><%= t.status[r.status] %></span></td>
              <td><%= r.hauler_name || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

  </div>

  <%- include('partials/footer') %>
</body>
</html>

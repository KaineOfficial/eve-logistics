<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>

<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <h1>Dashboard</h1>

    <div class="profile">
      <img src="<%= character.portrait %>" width="80" height="80">
      <div>
        <h2><%= character.name %></h2>
        <p><%= character.corporation %></p>
      </div>
    </div>

    <table>
      <tr>
        <td class="label">ID du personnage</td>
        <td><%= character.id %></td>
      </tr>
      <tr>
        <td class="label">Corporation</td>
        <td><%= character.corporation %></td>
      </tr>
    </table>
  </div>

<%- include('partials/footer') %>
</body>
</html>

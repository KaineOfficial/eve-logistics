<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('partials/head') %>
  <title><%= t.dashboard.title %> — Tilean Dominion</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">

    <div class="profile">
      <img src="<%= character.portrait %>" width="80" height="80">
      <div>
        <h2><%= character.name %></h2>
        <p><%= character.corporation %></p>
      </div>
    </div>

    <% if (character.allianceId === allianceId) { %>

      <div class="stat-cards">
        <div class="stat-card pending">
          <div class="stat-number"><%= stats.outstanding %></div>
          <div class="stat-label"><%= t.dashboard.outstanding %></div>
        </div>
        <div class="stat-card in-transit">
          <div class="stat-number"><%= stats.in_progress %></div>
          <div class="stat-label"><%= t.dashboard.inProgress %></div>
        </div>
        <div class="stat-card delivered">
          <div class="stat-number"><%= stats.finished %></div>
          <div class="stat-label"><%= t.dashboard.finished %></div>
        </div>
        <div class="stat-card cancelled">
          <div class="stat-number"><%= stats.cancelled %></div>
          <div class="stat-label"><%= t.dashboard.cancelled %></div>
        </div>
      </div>

      <% if (isHauler) { %>
      <div class="hauler-summary">
        <div>
          <div class="hauler-summary-text"><%= t.dashboard.haulerActive %></div>
          <div class="hauler-summary-count"><%= stats.outstanding %></div>
        </div>
        <a href="/logistics" class="nav-btn hauler"><%= t.dashboard.haulerBtn %></a>
      </div>
      <% } %>

      <!-- Graphique activité 7 jours -->
      <div class="chart-container">
        <canvas id="weekChart"></canvas>
      </div>

      <div class="section-header">
        <h2><%= t.dashboard.myRequests %></h2>
        <a href="/my-contracts"><%= t.dashboard.seeAll %></a>
      </div>

      <% if (myContracts.length === 0) { %>
        <p class="no-contracts"><%= t.dashboard.noRequests %></p>
      <% } else { %>
        <table class="contracts-table">
          <thead>
            <tr>
              <th>#</th>
              <th><%= t.dashboard.colRoute %></th>
              <th><%= t.dashboard.colVolume %></th>
              <th><%= t.dashboard.colReward %></th>
              <th><%= t.dashboard.colStatus %></th>
              <th><%= t.dashboard.colHauler %></th>
            </tr>
          </thead>
          <tbody>
            <% myContracts.forEach(c => { %>
              <tr>
                <td>#<%= c.contract_id %></td>
                <td><%= c.start_name %> → <%= c.end_name %></td>
                <td><%= c.volume ? c.volume.toLocaleString() : '—' %></td>
                <td><%= c.reward ? c.reward.toLocaleString() + ' ISK' : '—' %></td>
                <td><span class="status-badge status-<%= c.status %>"><%= t.status[c.status] || c.status %></span></td>
                <td><%= c.acceptor_name || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>

    <% } %>

  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script>
    const ctx = document.getElementById('weekChart');
    if (ctx) {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: <%- JSON.stringify(chartLabels) %>,
          datasets: [
            {
              label: '<%= t.dashboard.outstanding || "Created" %>',
              data: <%- JSON.stringify(chartCreated) %>,
              backgroundColor: 'rgba(251, 191, 36, 0.7)',
              borderRadius: 4,
            },
            {
              label: '<%= t.dashboard.finished || "Delivered" %>',
              data: <%- JSON.stringify(chartDelivered) %>,
              backgroundColor: 'rgba(74, 222, 128, 0.7)',
              borderRadius: 4,
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { labels: { color: getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#94a3b8' } },
          },
          scales: {
            x: { ticks: { color: '#94a3b8' }, grid: { display: false } },
            y: { ticks: { color: '#94a3b8', stepSize: 1 }, grid: { color: 'rgba(51,65,85,0.3)' }, beginAtZero: true }
          }
        }
      });
    }
  </script>
</body>
</html>

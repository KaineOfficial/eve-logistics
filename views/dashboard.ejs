<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Dashboard — TSLC</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">

    <!-- Profil -->
    <div class="profile">
      <img src="<%= character.portrait %>" width="80" height="80">
      <div>
        <h2><%= character.name %></h2>
        <p><%= character.corporation %></p>
      </div>
    </div>

    <!-- Stats globales -->
    <div class="stat-cards">
      <div class="stat-card pending">
        <div class="stat-number"><%= stats.pending %></div>
        <div class="stat-label">En attente</div>
      </div>
      <div class="stat-card accepted">
        <div class="stat-number"><%= stats.accepted %></div>
        <div class="stat-label">Acceptées</div>
      </div>
      <div class="stat-card in-transit">
        <div class="stat-number"><%= stats.in_transit %></div>
        <div class="stat-label">En transit</div>
      </div>
      <div class="stat-card delivered">
        <div class="stat-number"><%= stats.delivered %></div>
        <div class="stat-label">Livrées</div>
      </div>
    </div>

    <!-- Accès rapide Hauler (membres alliance) -->
    <% if (character.allianceId === allianceId) { %>
      <div class="hauler-summary">
        <div>
          <div class="hauler-summary-text">Demandes actives à traiter</div>
          <div class="hauler-summary-count"><%= activeCount %> demande<%= activeCount > 1 ? 's' : '' %></div>
        </div>
        <a href="/hauler" class="nav-btn hauler">Ouvrir le panel Hauler</a>
      </div>
    <% } %>

    <!-- Mes demandes récentes -->
    <div class="section-header">
      <h2>Mes demandes récentes</h2>
      <a href="/freight">Voir toutes →</a>
    </div>

    <% if (myRequests.length === 0) { %>
      <p class="no-contracts">Aucune demande soumise pour le moment. <a href="/freight/new" style="display:inline;padding:0;background:none;color:#3b82f6;font-weight:normal;">Créer une demande</a></p>
    <% } else { %>
      <table class="contracts-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Départ → Arrivée</th>
            <th>Volume (m³)</th>
            <th>Récompense</th>
            <th>Statut</th>
            <th>Hauler</th>
          </tr>
        </thead>
        <tbody>
          <% myRequests.forEach(r => { %>
            <tr>
              <td>#<%= r.id %></td>
              <td><%= r.pickup %> → <%= r.destination %></td>
              <td><%= r.volume.toLocaleString('fr-FR') %></td>
              <td><%= r.reward ? r.reward.toLocaleString('fr-FR') + ' ISK' : '—' %></td>
              <td><span class="status-badge status-<%= r.status %>"><%= statusLabels[r.status] %></span></td>
              <td><%= r.hauler_name || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

  </div>

  <%- include('partials/footer') %>
</body>
</html>

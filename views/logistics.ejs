<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <title><%= t.logistics.title %> — TSLC</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container wide">
    <div class="page-header">
      <h1><%= t.logistics.title %></h1>
    </div>

    <!-- Onglets -->
    <div class="tabs">
      <a href="/logistics" class="tab <%= tab === 'freight' ? 'active' : '' %>">
        <%= t.logistics.tabFreight %>
      </a>
      <a href="/logistics?tab=hauler" class="tab <%= tab === 'hauler' ? 'active' : '' %>">
        <%= t.logistics.tabHauler %>
      </a>
    </div>

    <% if (tab === 'freight') { %>
      <!-- ═══ ONGLET FREIGHT ═══ -->

      <!-- Carte standards de hauling -->
      <div class="standards-card">
        <div class="standards-header">
          <span class="standards-title"><%= t.freight.standardsTitle %></span>
        </div>
        <div class="standards-body">
          <div class="standards-section">
            <div class="standards-label"><%= t.freight.standardsVolume %></div>
            <div class="standards-value"><%= standards.maxVolume.toLocaleString() %> m³</div>
          </div>
          <div class="standards-section">
            <div class="standards-label"><%= t.freight.standardsCost %></div>
            <div class="standards-tiers">
              <% standards.tiers.forEach(tier => { %>
                <div class="standards-tier">
                  <span class="tier-limit">&le; <%= (tier.maxCollateral / 1e9).toLocaleString() %> B ISK</span>
                  <span class="tier-rate"><%= tier.ratePerM3.toLocaleString() %> ISK/m³</span>
                </div>
              <% }) %>
            </div>
          </div>
          <div class="standards-section">
            <div class="standards-label"><%= t.freight.standardsExpiry %></div>
            <div class="standards-value"><%= standards.expirationWeeks %> <%= t.freight.standardsWeeks %></div>
          </div>
          <div class="standards-section">
            <div class="standards-label"><%= t.freight.standardsDays %></div>
            <div class="standards-value"><%= standards.daysToComplete %> <%= t.freight.standardsDaysUnit %></div>
          </div>
        </div>
      </div>

      <% if (contracts.length === 0) { %>
        <p class="no-contracts"><%= t.freight.noRequests %></p>
      <% } else { %>
        <table class="contracts-table">
          <thead>
            <tr>
              <th><%= t.freight.colId %></th>
              <th><%= t.freight.colRequester %></th>
              <th><%= t.freight.colFrom %></th>
              <th><%= t.freight.colTo %></th>
              <th><%= t.freight.colVolume %></th>
              <th><%= t.freight.colCollateral %></th>
              <th><%= t.freight.colReward %></th>
              <th><%= t.freight.colStatus %></th>
              <th><%= t.freight.colHauler %></th>
            </tr>
          </thead>
          <tbody>
            <% contracts.forEach(c => { %>
              <tr>
                <td>#<%= c.contract_id %></td>
                <td><%= c.issuer_name %></td>
                <td><%= c.start_name %></td>
                <td><%= c.end_name %></td>
                <td><%= c.volume ? c.volume.toLocaleString() : '—' %></td>
                <td><%= c.collateral ? c.collateral.toLocaleString() + ' ISK' : '—' %></td>
                <td><%= c.reward ? c.reward.toLocaleString() + ' ISK' : '—' %></td>
                <td><span class="status-badge status-<%= c.status %>"><%= t.status[c.status] || c.status %></span></td>
                <td><%= c.acceptor_name || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>

    <% } else { %>
      <!-- ═══ ONGLET HAULER ═══ -->

      <p class="hauler-note"><%= t.hauler.inGameNote %></p>

      <% if (active.length === 0) { %>
        <p class="no-contracts"><%= t.hauler.noRequests %></p>
      <% } else { %>
        <%
          const outstanding = active.filter(c => c.status === 'outstanding');
          const inProgress  = active.filter(c => c.status === 'in_progress');
        %>

        <% if (outstanding.length > 0) { %>
          <div class="section-header">
            <h2><%= t.status.outstanding %> <span class="badge badge-outstanding"><%= outstanding.length %></span></h2>
          </div>
          <table class="contracts-table">
            <thead>
              <tr>
                <th>#</th>
                <th><%= t.freight.colRequester %></th>
                <th><%= t.freight.colFrom %></th>
                <th><%= t.freight.colTo %></th>
                <th><%= t.freight.colVolume %></th>
                <th><%= t.freight.colCollateral %></th>
                <th><%= t.freight.colReward %></th>
              </tr>
            </thead>
            <tbody>
              <% outstanding.forEach(c => { %>
                <tr>
                  <td>#<%= c.contract_id %></td>
                  <td><%= c.issuer_name %></td>
                  <td><%= c.start_name %></td>
                  <td><%= c.end_name %></td>
                  <td><%= c.volume ? c.volume.toLocaleString() : '—' %></td>
                  <td><%= c.collateral ? c.collateral.toLocaleString() + ' ISK' : '—' %></td>
                  <td><%= c.reward ? c.reward.toLocaleString() + ' ISK' : '—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>

        <% if (inProgress.length > 0) { %>
          <div class="section-header" style="margin-top:24px;">
            <h2><%= t.status.in_progress %> <span class="badge badge-inprogress"><%= inProgress.length %></span></h2>
          </div>
          <table class="contracts-table">
            <thead>
              <tr>
                <th>#</th>
                <th><%= t.freight.colRequester %></th>
                <th><%= t.freight.colFrom %></th>
                <th><%= t.freight.colTo %></th>
                <th><%= t.freight.colVolume %></th>
                <th><%= t.freight.colReward %></th>
                <th><%= t.freight.colHauler %></th>
              </tr>
            </thead>
            <tbody>
              <% inProgress.forEach(c => { %>
                <tr>
                  <td>#<%= c.contract_id %></td>
                  <td><%= c.issuer_name %></td>
                  <td><%= c.start_name %></td>
                  <td><%= c.end_name %></td>
                  <td><%= c.volume ? c.volume.toLocaleString() : '—' %></td>
                  <td><%= c.reward ? c.reward.toLocaleString() + ' ISK' : '—' %></td>
                  <td><%= c.acceptor_name || '—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>

      <% } %>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</body>
</html>

<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <title><%= t.logistics.title %> — TSLC</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container wide">
    <div class="page-header">
      <h1><%= t.logistics.title %></h1>
    </div>

    <!-- Carte standards de hauling -->
    <div class="standards-card">
      <div class="standards-header">
        <span class="standards-title"><%= t.freight.standardsTitle %></span>
      </div>
      <div class="standards-body">
        <div class="standards-section">
          <div class="standards-label"><%= t.freight.standardsVolume %></div>
          <div class="standards-value"><%= standards.maxVolume.toLocaleString() %> m³</div>
        </div>
        <div class="standards-section">
          <div class="standards-label"><%= t.freight.standardsCost %></div>
          <div class="standards-tiers">
            <% standards.tiers.forEach(tier => { %>
              <div class="standards-tier">
                <span class="tier-limit">&le; <%= (tier.maxCollateral / 1e9).toLocaleString() %> B ISK</span>
                <span class="tier-rate"><%= tier.ratePerM3.toLocaleString() %> ISK/m³</span>
              </div>
            <% }) %>
          </div>
        </div>
        <div class="standards-section">
          <div class="standards-label"><%= t.freight.standardsExpiry %></div>
          <div class="standards-value"><%= standards.expirationWeeks %> <%= t.freight.standardsWeeks %></div>
        </div>
        <div class="standards-section">
          <div class="standards-label"><%= t.freight.standardsDays %></div>
          <div class="standards-value"><%= standards.daysToComplete %> <%= t.freight.standardsDaysUnit %></div>
        </div>
      </div>
    </div>

    <p class="hauler-note"><%= t.hauler.inGameNote %></p>

    <!-- Filtres par statut -->
    <div class="filters" id="filters">
      <button class="filter-btn active" data-filter="all"><%= t.logistics.filterAll %> <span class="filter-count"><%= contracts.length %></span></button>
      <button class="filter-btn" data-filter="outstanding"><%= t.status.outstanding %> <span class="filter-count"><%= contracts.filter(c => c.status === 'outstanding').length %></span></button>
      <button class="filter-btn" data-filter="in_progress"><%= t.status.in_progress %> <span class="filter-count"><%= contracts.filter(c => c.status === 'in_progress').length %></span></button>
      <button class="filter-btn" data-filter="finished"><%= t.status.finished %> <span class="filter-count"><%= contracts.filter(c => ['finished','finished_issuer','finished_contractor'].includes(c.status)).length %></span></button>
      <button class="filter-btn" data-filter="cancelled"><%= t.status.cancelled %> <span class="filter-count"><%= contracts.filter(c => ['cancelled','rejected','failed','deleted','reversed'].includes(c.status)).length %></span></button>
    </div>

    <!-- Recherche -->
    <div class="search-bar">
      <input type="text" id="search-input" placeholder="<%= t.logistics.searchPlaceholder || 'Search...' %>" class="search-input">
    </div>

    <% if (contracts.length === 0) { %>
      <p class="no-contracts"><%= t.freight.noRequests %></p>
    <% } else { %>
      <table class="contracts-table sortable" id="contracts-table">
        <thead>
          <tr>
            <th data-sort="text"><%= t.freight.colId %></th>
            <th data-sort="text"><%= t.freight.colRequester %></th>
            <th data-sort="text"><%= t.freight.colFrom %></th>
            <th data-sort="text"><%= t.freight.colTo %></th>
            <th data-sort="num"><%= t.freight.colVolume %></th>
            <th data-sort="num"><%= t.freight.colCollateral %></th>
            <th data-sort="num"><%= t.freight.colReward %></th>
            <th data-sort="text"><%= t.freight.colStatus %></th>
            <th data-sort="text"><%= t.freight.colHauler %></th>
            <th data-sort="text"><%= t.logistics.colTimeLeft %></th>
          </tr>
        </thead>
        <tbody>
          <% contracts.forEach(c => { %>
            <%
              // Groupe de statut pour le filtre
              let filterGroup = c.status;
              if (['finished_issuer','finished_contractor'].includes(c.status)) filterGroup = 'finished';
              if (['rejected','failed','deleted','reversed'].includes(c.status)) filterGroup = 'cancelled';

              // Calcul temps restant
              let timeLeft = '';
              const now = new Date();
              if (c.status === 'outstanding' && c.date_expired) {
                const diff = new Date(c.date_expired) - now;
                if (diff > 0) {
                  const days = Math.floor(diff / 86400000);
                  const hrs  = Math.floor((diff % 86400000) / 3600000);
                  timeLeft = days > 0 ? days + 'j ' + hrs + 'h' : hrs + 'h';
                }
              } else if (c.status === 'in_progress' && c.date_accepted && c.days_to_complete) {
                const deadline = new Date(new Date(c.date_accepted).getTime() + c.days_to_complete * 86400000);
                const diff = deadline - now;
                if (diff > 0) {
                  const days = Math.floor(diff / 86400000);
                  const hrs  = Math.floor((diff % 86400000) / 3600000);
                  timeLeft = days > 0 ? days + 'j ' + hrs + 'h' : hrs + 'h';
                }
              }
            %>
            <tr data-status="<%= filterGroup %>">
              <td>#<%= c.contract_id %></td>
              <td><%= c.issuer_name %></td>
              <td><%= c.start_name %></td>
              <td><%= c.end_name %></td>
              <td><%= c.volume ? c.volume.toLocaleString() : '—' %></td>
              <td><%= c.collateral ? c.collateral.toLocaleString() + ' ISK' : '—' %></td>
              <td><%= c.reward ? c.reward.toLocaleString() + ' ISK' : '—' %></td>
              <td><span class="status-badge status-<%= c.status %>"><%= t.status[c.status] || c.status %></span></td>
              <td><%= c.acceptor_name || '—' %></td>
              <td class="time-left"><%= timeLeft || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <%- include('partials/footer') %>

  <script>
    const activeFilter = () => document.querySelector('.filter-btn.active')?.dataset.filter || 'all';

    function applyVisibility() {
      const q = (document.getElementById('search-input')?.value || '').toLowerCase();
      const filter = activeFilter();
      document.querySelectorAll('#contracts-table tbody tr').forEach(row => {
        const matchFilter = filter === 'all' || row.dataset.status === filter;
        const matchSearch = !q || row.textContent.toLowerCase().includes(q);
        row.style.display = (matchFilter && matchSearch) ? '' : 'none';
      });
    }

    // Filtrage
    document.getElementById('filters')?.addEventListener('click', e => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyVisibility();
    });

    // Recherche
    document.getElementById('search-input')?.addEventListener('input', applyVisibility);

    // Tri colonnes
    document.querySelectorAll('.sortable th[data-sort]').forEach((th, colIdx) => {
      th.style.cursor = 'pointer';
      th.addEventListener('click', () => {
        const tbody = document.querySelector('#contracts-table tbody');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const type = th.dataset.sort;
        const asc = th.dataset.dir !== 'asc';
        document.querySelectorAll('.sortable th').forEach(h => delete h.dataset.dir);
        th.dataset.dir = asc ? 'asc' : 'desc';
        rows.sort((a, b) => {
          let va = a.cells[colIdx]?.textContent.trim() || '';
          let vb = b.cells[colIdx]?.textContent.trim() || '';
          if (type === 'num') {
            va = parseFloat(va.replace(/[^0-9.\-]/g, '')) || 0;
            vb = parseFloat(vb.replace(/[^0-9.\-]/g, '')) || 0;
            return asc ? va - vb : vb - va;
          }
          return asc ? va.localeCompare(vb) : vb.localeCompare(va);
        });
        rows.forEach(r => tbody.appendChild(r));
      });
    });
  </script>
</body>
</html>

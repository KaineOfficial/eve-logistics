<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <title><%= t.freight.title %> — TSLC</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container wide">
    <div class="page-header">
      <h1><%= t.freight.title %></h1>
      <a href="/freight/new" class="nav-btn refresh"><%= t.freight.newBtn %></a>
    </div>

    <% if (requests.length === 0) { %>
      <p class="no-contracts"><%= t.freight.noRequests %></p>
    <% } else { %>
      <table class="contracts-table">
        <thead>
          <tr>
            <th><%= t.freight.colId %></th>
            <th><%= t.freight.colRequester %></th>
            <th><%= t.freight.colFrom %></th>
            <th><%= t.freight.colTo %></th>
            <th><%= t.freight.colVolume %></th>
            <th><%= t.freight.colCollateral %></th>
            <th><%= t.freight.colReward %></th>
            <th><%= t.freight.colStatus %></th>
            <th><%= t.freight.colHauler %></th>
          </tr>
        </thead>
        <tbody>
          <% requests.forEach(r => { %>
            <tr>
              <td>#<%= r.id %></td>
              <td><%= r.char_name %></td>
              <td><%= r.pickup %></td>
              <td><%= r.destination %></td>
              <td><%= r.volume.toLocaleString() %></td>
              <td><%= r.collateral.toLocaleString() %> ISK</td>
              <td><%= r.reward ? r.reward.toLocaleString() + ' ISK' : '—' %></td>
              <td><span class="status-badge status-<%= r.status %>"><%= t.status[r.status] %></span></td>
              <td><%= r.hauler_name || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</body>
</html>

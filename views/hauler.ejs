<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <title><%= t.hauler.title %> — TSLC</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container wide">
    <h1><%= t.hauler.title %></h1>
    <p style="color:#94a3b8;"><%= t.hauler.connectedAs %> <strong><%= character.name %></strong></p>

    <% if (requests.length === 0) { %>
      <p class="no-contracts"><%= t.hauler.noRequests %></p>
    <% } else { %>
      <% requests.forEach(r => { %>
        <div class="hauler-card">
          <div class="hauler-card-header">
            <span>#<%= r.id %> — <strong><%= r.char_name %></strong></span>
            <span class="status-badge status-<%= r.status %>"><%= t.status[r.status] %></span>
          </div>
          <div class="hauler-card-body">
            <div class="hauler-info">
              <span><strong><%= t.hauler.labelFrom %></strong> <%= r.pickup %></span>
              <span><strong><%= t.hauler.labelTo %></strong> <%= r.destination %></span>
              <span><strong><%= t.hauler.labelVolume %></strong> <%= r.volume.toLocaleString() %> m³</span>
              <span><strong><%= t.hauler.labelCollateral %></strong> <%= r.collateral.toLocaleString() %> ISK</span>
              <span><strong><%= t.hauler.labelReward %></strong> <%= r.reward ? r.reward.toLocaleString() + ' ISK' : '—' %></span>
              <% if (r.notes) { %><span><strong><%= t.hauler.labelNotes %></strong> <%= r.notes %></span><% } %>
              <% if (r.hauler_name) { %><span><strong><%= t.hauler.labelHauler %></strong> <%= r.hauler_name %></span><% } %>
            </div>
            <form class="status-form" action="/hauler/<%= r.id %>/status" method="POST">
              <select name="status" class="status-select">
                <option value="pending"    <%= r.status === 'pending'    ? 'selected' : '' %>><%= t.status.pending %></option>
                <option value="accepted"   <%= r.status === 'accepted'   ? 'selected' : '' %>><%= t.status.accepted %></option>
                <option value="in_transit" <%= r.status === 'in_transit' ? 'selected' : '' %>><%= t.status.in_transit %></option>
                <option value="delivered"  <%= r.status === 'delivered'  ? 'selected' : '' %>><%= t.status.delivered %></option>
                <option value="cancelled"  <%= r.status === 'cancelled'  ? 'selected' : '' %>><%= t.status.cancelled %></option>
              </select>
              <button type="submit" class="nav-btn refresh"><%= t.hauler.updateBtn %></button>
            </form>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</body>
</html>

<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('partials/head') %>
  <title>Sales — EVE Logistics</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container wide">
    <div class="page-header">
      <h1>License Management</h1>
    </div>

    <!-- Stats -->
    <div class="stat-cards">
      <div class="stat-card pending">
        <div class="stat-number"><%= salesStats.total %></div>
        <div class="stat-label">Total Licenses</div>
      </div>
      <div class="stat-card delivered">
        <div class="stat-number"><%= salesStats.active %></div>
        <div class="stat-label">Active</div>
      </div>
      <div class="stat-card accepted">
        <div class="stat-number"><%= salesStats.totalIsk.toLocaleString() %></div>
        <div class="stat-label">Total ISK</div>
      </div>
      <div class="stat-card in-transit">
        <div class="stat-number"><%= salesStats.monthIsk.toLocaleString() %></div>
        <div class="stat-label">This Month ISK</div>
      </div>
    </div>

    <!-- Generate new license -->
    <div class="admin-section">
      <h2 class="admin-section-title">Generate License</h2>
      <form method="POST" action="/sales/generate">
        <div class="admin-grid">
          <div class="form-group">
            <label>Alliance ID</label>
            <input type="number" name="allianceId" required>
          </div>
          <div class="form-group">
            <label>Client Name</label>
            <input type="text" name="clientName" placeholder="e.g. Goonswarm Federation" required>
          </div>
          <div class="form-group">
            <label>Type</label>
            <select name="type" class="search-input" style="cursor:pointer">
              <option value="one-shot">One-shot (permanent)</option>
              <option value="monthly">Monthly (30 days)</option>
              <option value="yearly">Yearly (365 days)</option>
              <option value="custom">Custom expiry</option>
            </select>
          </div>
          <div class="form-group">
            <label>ISK Paid</label>
            <input type="number" name="iskPaid" value="0" min="0">
          </div>
          <div class="form-group">
            <label>Custom expiry (optional)</label>
            <input type="date" name="expiresAt">
          </div>
          <div class="form-group">
            <label>Notes</label>
            <input type="text" name="notes" placeholder="Optional notes">
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="submit-btn">Generate License Key</button>
        </div>
      </form>
    </div>

    <!-- Licenses list -->
    <div class="admin-section">
      <h2 class="admin-section-title">Licenses (<%= licenses.length %>)</h2>
      <% if (licenses.length === 0) { %>
        <p class="no-contracts">No licenses generated yet.</p>
      <% } else { %>
        <table class="contracts-table">
          <thead>
            <tr>
              <th>Client</th>
              <th>Alliance ID</th>
              <th>Type</th>
              <th>ISK</th>
              <th>Status</th>
              <th>Expires</th>
              <th>Key</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% licenses.forEach(l => { %>
              <%
                const isExpired = l.expires_at && new Date(l.expires_at) < new Date();
                const statusClass = !l.active ? 'status-failed' : isExpired ? 'status-cancelled' : 'status-outstanding';
                const statusText = !l.active ? 'Revoked' : isExpired ? 'Expired' : 'Active';
              %>
              <tr>
                <td><strong><%= l.client_name %></strong></td>
                <td><%= l.alliance_id %></td>
                <td><%= l.type %></td>
                <td><%= l.isk_paid ? l.isk_paid.toLocaleString() + ' ISK' : '—' %></td>
                <td><span class="status-badge <%= statusClass %>"><%= statusText %></span></td>
                <td style="white-space:nowrap"><%= l.expires_at ? new Date(l.expires_at).toLocaleDateString() : 'Permanent' %></td>
                <td>
                  <button class="copy-btn" onclick="copyKey(this, '<%= l.license_key %>')" style="margin:0;padding:4px 8px;font-size:0.75rem">Copy</button>
                </td>
                <td>
                  <div style="display:flex;gap:4px">
                    <% if (l.active) { %>
                      <form method="POST" action="/sales/<%= l.id %>/revoke" style="display:inline">
                        <button type="submit" class="btn-remove-tier" style="font-size:0.75rem;padding:4px 8px">Revoke</button>
                      </form>
                    <% } else { %>
                      <form method="POST" action="/sales/<%= l.id %>/activate" style="display:inline">
                        <button type="submit" class="btn-toggle active" style="font-size:0.75rem;padding:4px 8px">Reactivate</button>
                      </form>
                    <% } %>
                    <form method="POST" action="/sales/<%= l.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this license permanently?')">
                      <button type="submit" class="btn-remove-tier" style="font-size:0.75rem;padding:4px 8px">X</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% if (l.notes) { %>
                <tr><td colspan="8" style="font-size:0.8rem;color:#64748b;padding:2px 10px 8px">Note: <%= l.notes %></td></tr>
              <% } %>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    function copyKey(btn, key) {
      navigator.clipboard.writeText(key).then(() => {
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
      });
    }
  </script>
</body>
</html>

<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <title><%= t.freightNew.title %> — TSLC</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <h1><%= t.freightNew.title %></h1>

    <form class="freight-form" action="/freight/new" method="POST">

      <div class="form-row">
        <div class="form-group">
          <label><%= t.freightNew.labelFrom %></label>
          <input type="text" name="pickup" required placeholder="<%= t.freightNew.placeholderFrom %>">
        </div>
        <div class="form-group">
          <label><%= t.freightNew.labelTo %></label>
          <input type="text" name="destination" required placeholder="<%= t.freightNew.placeholderTo %>">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label><%= t.freightNew.labelVolume %></label>
          <input type="number" name="volume" required min="1" step="0.01" placeholder="<%= t.freightNew.placeholderVolume %>">
        </div>
        <div class="form-group">
          <label><%= t.freightNew.labelCollateral %></label>
          <input type="number" name="collateral" required min="0" step="1" placeholder="<%= t.freightNew.placeholderCollateral %>">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label><%= t.freightNew.labelReward %> <span class="optional"><%= t.freightNew.optional %></span></label>
          <input type="number" name="reward" min="0" step="1" placeholder="<%= t.freightNew.placeholderReward %>">
        </div>
        <div class="form-group">
          <label><%= t.freightNew.labelNotes %> <span class="optional"><%= t.freightNew.optional %></span></label>
          <input type="text" name="notes" placeholder="<%= t.freightNew.placeholderNotes %>">
        </div>
      </div>

      <button type="submit" class="submit-btn"><%= t.freightNew.submitBtn %></button>
    </form>
  </div>

  <%- include('partials/footer') %>
</body>
</html>

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Nouvelle demande — TSLC</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <h1>Nouvelle demande de transport</h1>

    <form class="freight-form" action="/freight/new" method="POST">

      <div class="form-row">
        <div class="form-group">
          <label>Système / Station de départ</label>
          <input type="text" name="pickup" required placeholder="ex: Jita IV - Moon 4">
        </div>
        <div class="form-group">
          <label>Système / Station d'arrivée</label>
          <input type="text" name="destination" required placeholder="ex: Amarr VIII - Imperial">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Volume (m³)</label>
          <input type="number" name="volume" required min="1" step="0.01" placeholder="ex: 50000">
        </div>
        <div class="form-group">
          <label>Valeur de la cargaison (ISK)</label>
          <input type="number" name="collateral" required min="0" step="1" placeholder="ex: 1000000000">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Récompense proposée (ISK) <span class="optional">optionnel</span></label>
          <input type="number" name="reward" min="0" step="1" placeholder="ex: 50000000">
        </div>
        <div class="form-group">
          <label>Notes <span class="optional">optionnel</span></label>
          <input type="text" name="notes" placeholder="Informations complémentaires...">
        </div>
      </div>

      <button type="submit" class="submit-btn">Soumettre la demande</button>
    </form>
  </div>

  <%- include('partials/footer') %>
</body>
</html>

<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <title><%= t.freightNew.title %> — TSLC</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <h1><%= t.freightNew.title %></h1>

    <form class="freight-form" action="/freight/new" method="POST">

      <div class="form-row">
        <div class="form-group">
          <label><%= t.freightNew.labelFrom %></label>
          <div class="autocomplete-wrapper">
            <input type="text" id="pickup" name="pickup" required
                   autocomplete="off"
                   placeholder="<%= t.freightNew.placeholderFrom %>">
            <div class="autocomplete-dropdown" id="pickup-dropdown" hidden></div>
          </div>
        </div>
        <div class="form-group">
          <label><%= t.freightNew.labelTo %></label>
          <div class="autocomplete-wrapper">
            <input type="text" id="destination" name="destination" required
                   autocomplete="off"
                   placeholder="<%= t.freightNew.placeholderTo %>">
            <div class="autocomplete-dropdown" id="destination-dropdown" hidden></div>
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>
            <%= t.freightNew.labelVolume %>
            <span class="optional"><%= t.freightNew.maxVolume %></span>
          </label>
          <input type="number" id="volume" name="volume" required min="1"
                 max="<%= freightConfig.maxVolume %>" step="1"
                 placeholder="<%= t.freightNew.placeholderVolume %>">
        </div>
        <div class="form-group">
          <label>
            <%= t.freightNew.labelCollateral %>
            <span class="optional"><%= t.freightNew.maxCollateral %></span>
          </label>
          <input type="number" id="collateral" name="collateral" required min="0"
                 max="<%= freightConfig.maxCollateral %>" step="1"
                 placeholder="<%= t.freightNew.placeholderCollateral %>">
        </div>
      </div>

      <div id="price-summary" class="price-summary" hidden></div>

      <div class="form-row">
        <div class="form-group">
          <label>
            <%= t.freightNew.labelReward %>
            <span class="optional"><%= t.freightNew.autoCalc %></span>
          </label>
          <input type="number" id="reward" name="reward" min="0" step="1" readonly
                 placeholder="<%= t.freightNew.placeholderReward %>">
        </div>
        <div class="form-group">
          <label><%= t.freightNew.labelNotes %> <span class="optional"><%= t.freightNew.optional %></span></label>
          <input type="text" name="notes" placeholder="<%= t.freightNew.placeholderNotes %>">
        </div>
      </div>

      <!-- Tableau des paliers tarifaires -->
      <div class="pricing-table">
        <div class="pricing-table-title"><%= t.freightNew.pricingTitle %></div>
        <% freightConfig.tiers.forEach(tier => { %>
          <div class="pricing-row">
            <span class="pricing-limit">&le; <%= (tier.maxCollateral / 1e9).toLocaleString() %> B ISK</span>
            <span class="pricing-rate"><%= tier.ratePerM3.toLocaleString() %> ISK/m³</span>
          </div>
        <% }) %>
        <div class="pricing-row pricing-limit-row">
          <span class="pricing-limit"><%= t.freightNew.volMax %> <%= freightConfig.maxVolume.toLocaleString() %> m³</span>
        </div>
      </div>

      <button type="submit" class="submit-btn"><%= t.freightNew.submitBtn %></button>
    </form>
  </div>

  <%- include('partials/footer') %>

  <script>
    const FREIGHT_CONFIG = <%- JSON.stringify(freightConfig) %>;

    // ── Autocomplete stations ──────────────────────────────────────────────
    function setupAutocomplete(inputEl, dropdownEl) {
      let timer;
      inputEl.addEventListener('input', () => {
        clearTimeout(timer);
        const q = inputEl.value.trim();
        if (q.length < 3) { dropdownEl.hidden = true; return; }
        timer = setTimeout(async () => {
          try {
            const res  = await fetch('/api/stations?q=' + encodeURIComponent(q));
            const list = await res.json();
            dropdownEl.innerHTML = '';
            list.forEach(name => {
              const div = document.createElement('div');
              div.className   = 'autocomplete-item';
              div.textContent = name;
              div.addEventListener('mousedown', () => {
                inputEl.value    = name;
                dropdownEl.hidden = true;
              });
              dropdownEl.appendChild(div);
            });
            dropdownEl.hidden = list.length === 0;
          } catch { dropdownEl.hidden = true; }
        }, 300);
      });
      inputEl.addEventListener('blur', () => {
        setTimeout(() => { dropdownEl.hidden = true; }, 150);
      });
    }

    setupAutocomplete(
      document.getElementById('pickup'),
      document.getElementById('pickup-dropdown')
    );
    setupAutocomplete(
      document.getElementById('destination'),
      document.getElementById('destination-dropdown')
    );

    // ── Calculateur de prix ────────────────────────────────────────────────
    const summaryEl  = document.getElementById('price-summary');
    const rewardEl   = document.getElementById('reward');
    const volumeEl   = document.getElementById('volume');
    const collateralEl = document.getElementById('collateral');

    function calcReward() {
      const vol = parseFloat(volumeEl.value) || 0;
      const col = parseFloat(collateralEl.value) || 0;

      if (vol <= 0 || col <= 0) { summaryEl.hidden = true; rewardEl.value = ''; return; }

      if (vol > FREIGHT_CONFIG.maxVolume) {
        summaryEl.hidden = false;
        summaryEl.innerHTML = '<span class="price-error"><%= t.freightNew.errorVolume %></span>';
        rewardEl.value = '';
        return;
      }

      const tier = FREIGHT_CONFIG.tiers.find(t => col <= t.maxCollateral);
      if (!tier) {
        summaryEl.hidden = false;
        summaryEl.innerHTML = '<span class="price-error"><%= t.freightNew.errorCollateral %></span>';
        rewardEl.value = '';
        return;
      }

      const reward = Math.ceil(vol * tier.ratePerM3);
      rewardEl.value = reward;
      summaryEl.hidden = false;
      summaryEl.innerHTML =
        '<span class="price-rate">' + tier.ratePerM3.toLocaleString() + ' ISK/m\u00b3</span>' +
        ' \u00d7 ' + vol.toLocaleString() + ' m\u00b3 = ' +
        '<strong>' + reward.toLocaleString() + ' ISK</strong>';
    }

    volumeEl.addEventListener('input', calcReward);
    collateralEl.addEventListener('input', calcReward);
  </script>
</body>
</html>
